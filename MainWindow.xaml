<Window x:Class="Source2AllSensitivityConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Source2AllSensitivityConverter.ViewModels"
        Title="Source → All Sensitivity Converter" Height="640" Width="980"
        WindowStartupLocation="CenterScreen" Background="#1E1F22">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6E6E6"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinWidth" Value="90"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Input panel: a game's sensitivity, or a cm/360 + DPI -->
        <Border Grid.Row="0" Background="#2B2D31" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Input by:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0"/>
                    <RadioButton Content="Game sensitivity" GroupName="mode"
                                 IsChecked="{Binding InputBySensitivity, Mode=TwoWay}"/>
                    <RadioButton Content="cm/360 + DPI" GroupName="mode"
                                 IsChecked="{Binding InputByCm360, Mode=TwoWay}"/>
                </StackPanel>

                <!-- Game sensitivity input -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding InputBySensitivity, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Input game:" VerticalAlignment="Center"/>
                    <ComboBox Width="220" Margin="8,0,0,0" VerticalAlignment="Center"
                              ItemsSource="{Binding SourceOptions}"
                              SelectedItem="{Binding SelectedSource}"
                              DisplayMemberPath="Display"/>
                    <TextBlock Text="Sensitivity:" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    <TextBox Width="80" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14"
                             Text="{Binding SourceSensitivityText, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Detect from game" Margin="14,0,0,0" Command="{Binding DetectCommand}"/>
                </StackPanel>

                <!-- cm/360 + DPI input -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding InputByCm360, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="cm/360:" VerticalAlignment="Center"/>
                    <TextBox Width="80" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14"
                             Text="{Binding Cm360Text, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="DPI:" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    <TextBox Width="80" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14"
                             Text="{Binding DpiText, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <TextBlock Text="{Binding InputSummary}" Foreground="#9AA0A6" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Scan for games" Command="{Binding ScanCommand}" MinWidth="120"/>
            <Button Content="Select all" Command="{Binding SelectAllCommand}"/>
            <Button Content="Select none" Command="{Binding SelectNoneCommand}"/>
            <Button Content="Apply to selected" Command="{Binding ApplyCommand}" MinWidth="130"
                    FontWeight="SemiBold"/>
            <CheckBox Content="Allow experimental auto-apply" Foreground="#E6E6E6"
                      VerticalAlignment="Center" Margin="8,0,0,0"
                      IsChecked="{Binding AllowExperimentalApply}"
                      ToolTip="Un-greys games that have a known conversion but no safe config writer.&#x0a;Source games still get their config edited (with a .s2a-backup).&#x0a;Other games export their value to a file on your Desktop + clipboard instead of editing unknown config formats."/>
        </StackPanel>

        <!-- Games list + details -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0" ItemsSource="{Binding Games}" Background="#2B2D31"
                      BorderBrush="#3A3C41" Foreground="#E6E6E6"
                      SelectedItem="{Binding SelectedRow}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <!-- Grey out games that cannot be auto-applied -->
                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="40">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              IsEnabled="{Binding IsEnabled}"
                                              HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Game" Width="300"
                                        DisplayMemberBinding="{Binding DisplayName}"/>
                        <GridViewColumn Header="Store" Width="70"
                                        DisplayMemberBinding="{Binding StoreText}"/>
                        <GridViewColumn Header="Engine" Width="90"
                                        DisplayMemberBinding="{Binding EngineText}"/>
                        <GridViewColumn Header="Output sens" Width="90"
                                        DisplayMemberBinding="{Binding OutputText}"/>
                        <GridViewColumn Header="Status" Width="100"
                                        DisplayMemberBinding="{Binding StatusText}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Border Grid.Column="1" Background="#2B2D31" CornerRadius="6"
                    Margin="10,0,0,0" Padding="12" BorderBrush="#3A3C41" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Details" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SelectedDetails}" TextWrapping="Wrap"
                               Foreground="#C9CCd1" FontFamily="Consolas" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#2B2D31" CornerRadius="6" Padding="10" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#9AA0A6" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
