<Window x:Class="Source2AllSensitivityConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Source2AllSensitivityConverter.ViewModels"
        Title="Sensitivity Converter" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Background="{StaticResource WindowBrush}"
        TextOptions.TextFormattingMode="Ideal" FontFamily="Segoe UI" FontSize="13">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Width="34" Height="34" CornerRadius="8" Background="{StaticResource AccentBrush}"
                    VerticalAlignment="Center">
                <TextBlock Text="360" FontWeight="Bold" FontSize="12" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Sensitivity Converter" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="Match your aim across every game"
                           Foreground="{StaticResource SubTextBrush}" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <TabControl Grid.Row="1">

            <!-- ================= Convert tab ================= -->
            <TabItem Header="Convert">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="24" VerticalAlignment="Top">
                    <StackPanel MaxWidth="520" HorizontalAlignment="Left">

                        <TextBlock Text="Your sensitivity" Foreground="{StaticResource SubTextBrush}"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" ItemsSource="{Binding SourceOptions}"
                                      SelectedItem="{Binding ConvertFrom}" DisplayMemberPath="Display"/>
                            <TextBox Grid.Column="1" Margin="10,0,0,0" FontSize="15"
                                     Text="{Binding ConvertSensitivityText, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <TextBlock Text="Convert to" Foreground="{StaticResource SubTextBrush}"
                                   Margin="0,16,0,6"/>
                        <ComboBox ItemsSource="{Binding SourceOptions}"
                                  SelectedItem="{Binding ConvertTo}" DisplayMemberPath="Display"/>

                        <TextBlock Text="Result" Foreground="{StaticResource SubTextBrush}" Margin="0,20,0,6"/>
                        <Grid>
                            <Border Background="{StaticResource Surface2Brush}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Height="64">
                                <TextBox Text="{Binding ConvertOutput, Mode=OneWay}" IsReadOnly="True"
                                         Background="Transparent" BorderThickness="0"
                                         FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                         VerticalContentAlignment="Center" Margin="16,0,90,0"
                                         IsTabStop="False"/>
                            </Border>
                            <Button Content="Copy" Command="{Binding CopyConvertCommand}"
                                    Style="{StaticResource AccentButton}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,10,0" MinWidth="70"/>
                        </Grid>
                        <TextBlock Text="{Binding ConvertNote}" Foreground="{StaticResource SubTextBrush}"
                                   FontSize="12" Margin="2,8,0,0"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ================= Auto-apply tab ================= -->
            <TabItem Header="Auto-apply">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Input panel -->
                    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Input by" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Foreground="{StaticResource SubTextBrush}" Margin="0,0,16,0"/>
                                <RadioButton Content="Game sensitivity" GroupName="mode"
                                             IsChecked="{Binding InputBySensitivity, Mode=TwoWay}"/>
                                <RadioButton Content="cm/360 + DPI" GroupName="mode"
                                             IsChecked="{Binding InputByCm360, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        Visibility="{Binding InputBySensitivity, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Game" VerticalAlignment="Center" Foreground="{StaticResource SubTextBrush}"/>
                                <ComboBox Width="240" Margin="8,0,0,0" VerticalAlignment="Center"
                                          ItemsSource="{Binding SourceOptions}"
                                          SelectedItem="{Binding SelectedSource}" DisplayMemberPath="Display"/>
                                <TextBlock Text="Sensitivity" VerticalAlignment="Center" Margin="16,0,0,0"
                                           Foreground="{StaticResource SubTextBrush}"/>
                                <TextBox Width="90" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14"
                                         Text="{Binding SourceSensitivityText, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Content="Detect from game" Margin="16,0,0,0" Command="{Binding DetectCommand}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        Visibility="{Binding InputByCm360, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="cm/360" VerticalAlignment="Center" Foreground="{StaticResource SubTextBrush}"/>
                                <TextBox Width="90" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14"
                                         Text="{Binding Cm360Text, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="DPI" VerticalAlignment="Center" Margin="16,0,0,0"
                                           Foreground="{StaticResource SubTextBrush}"/>
                                <TextBox Width="90" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14"
                                         Text="{Binding DpiText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding InputSummary}" Foreground="{StaticResource AccentBrush}"
                                       Margin="0,12,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Scan for games" Command="{Binding ScanCommand}" MinWidth="120"
                                Style="{StaticResource AccentButton}"/>
                        <Button Content="Select all" Command="{Binding SelectAllCommand}"/>
                        <Button Content="Select none" Command="{Binding SelectNoneCommand}"/>
                        <Button Content="Apply to selected" Command="{Binding ApplyCommand}" MinWidth="140"
                                Style="{StaticResource AccentButton}"/>
                        <Button Content="Manually add game" Click="OnManuallyAddGame" MinWidth="140"/>
                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource SubTextBrush}"
                                   Text="Greyed games can't be auto-applied — copy their value from the Output column."/>
                    </StackPanel>

                    <!-- Games list + details -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="330"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <ListView ItemsSource="{Binding Games}" BorderThickness="0"
                                      SelectedItem="{Binding SelectedRow}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Width="42">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              IsEnabled="{Binding IsEnabled}"
                                                              HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Game" Width="290"
                                                        DisplayMemberBinding="{Binding DisplayName}"/>
                                        <GridViewColumn Header="Store" Width="70"
                                                        DisplayMemberBinding="{Binding StoreText}"/>
                                        <GridViewColumn Header="Engine" Width="90"
                                                        DisplayMemberBinding="{Binding EngineText}"/>
                                        <GridViewColumn Header="Output sens (copy)" Width="135">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="≈" Foreground="{StaticResource SubTextBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,3,0"
                                                                   ToolTip="Conversion factor for this game is approximate."
                                                                   Visibility="{Binding IsApproximate, Converter={StaticResource BoolToVis}}"/>
                                                        <TextBox Text="{Binding OutputValue, Mode=OneWay}" IsReadOnly="True"
                                                                 BorderThickness="0" Background="Transparent"
                                                                 Foreground="{StaticResource TextBrush}" Padding="0"
                                                                 MinWidth="80" IsTabStop="False" VerticalAlignment="Center"
                                                                 ToolTip="Read-only — click and Ctrl+C to copy."/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Status" Width="95"
                                                        DisplayMemberBinding="{Binding StatusText}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>

                        <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                                Margin="12,0,0,0" Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Details" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding SelectedDetails}" TextWrapping="Wrap"
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontFamily="Cascadia Mono, Consolas" FontSize="12" LineHeight="18"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Status bar -->
                    <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="12"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,12,0,0">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SubTextBrush}" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
